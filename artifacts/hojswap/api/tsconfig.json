{
    "extends": "../../../tsconfig.base.json",
    "compilerOptions": {
        "lib": [
            "es2022"
        ],
        "types": [
            "node"
        ],
        "target": "es2022",
        "module": "esnext",
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "strict": true
    },
    "include": [
        "./**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}